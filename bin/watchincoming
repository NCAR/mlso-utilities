#!/usr/bin/env python

"""Watches a directory for new files and then copies them to another directory
when they are completely done writing. This is useful because sometimes files
are written very slowly, or pause during writing, which causes the pipeline to
think they are done writing and it starts to process a partial file.

The directories involved and other options are in the file `watchincoming.cfg`
in the same directory as this script. The config file has sections which
correspond to the instrument name passed to this script on start up, i.e.:

```console
$ watchincoming kcor
```

will use the "kcor" section of `watchincoming.cfg`:

```ini
[kcor]
log_basename_format : {date}.kcor.transfer.log

incoming_basedir    : /export/data1/Data/KCor/raw/transfer
raw_basedir         : /export/data1/Data/KCor/raw
logging_basedir     : /hao/acos/kcor/logs

full_filesize       : 16782976
```
"""
import argparse
import configparser
import datetime
from email.mime.text import MIMEText
import logging
import os
import shutil
import signal
import smtplib
import sys

import inotify.adapters
import inotify.constants


WATCH_EVENT_FLAGS = inotify.constants.IN_CLOSE_WRITE
FITS_EXTENSIONS = ["fts", "fits"]

# rw-rw-r--
REQUIRED_PERMISSIONS = 0o664

logger: logging.Logger = None


def handle_exit(sig: int, frame):
    """Gracefully exit when killed suddenly.
    """
    signal_name = signal.Signals(sig).name
    logger.info(f"killed [{signal_name}]")
    sys.exit(0)

# register the signal handler for a clean exit
signal.signal(signal.SIGTERM, handle_exit)
signal.signal(signal.SIGINT, handle_exit)


def notify(to: str, subject: str, msg: str):
    """Send notication email.
    """
    mime_msg = MIMEText(msg)
    mime_msg["Subject"] = subject
    mime_msg["From"] = "watchincoming@ucar.edu"
    mime_msg["To"] = to

    try:
        s = smtplib.SMTP("localhost")
        s.send_message(mime_msg)
        s.quit()
        logger.info(f"sent notification to {to}")
    except ConnectionRefusedError as e:
        logger.error(e)
        logger.error(f"problem sending email: {msg['Subject']}")


def check_file(incoming_filename: str, full_filesize: int, machine_log_name: str):
    """Check an incoming file to see if it is OK to copy to the raw directory.
    """
    incoming_filesize = os.path.getsize(incoming_filename)
    logger.debug(f"file size: {incoming_filesize}")
    filename, extension = os.path.splitext(incoming_filename)
    is_machine_log = os.path.basename(incoming_filename) == machine_log_name
    logger.debug(f"machine log?" + ("YES" if is_machine_log else "NO"))
    ok = extension.lower() not in FITS_EXTENSIONS or incoming_filesize == full_filesize
    logger.debug(f"OK?" + ("YES" if ok else "NO"))
    return ok, is_machine_log, incoming_filesize


def get_current_date():
    """Get the current date in the format "YYYYMMDD" as used in the directory name
    of the watched directory.
    """
    return datetime.datetime.now().strftime("%Y%m%d")


def change_date(
    config: configparser.ConfigParser,
    instrument: str,
    notifier: inotify.adapters.Inotify,
    old_watch_id: int,
    new_date: str,
):
    """Change the current date, i.e., watch the directory corresponding to
    `new_date` and stop watching the old date directory.
    """

    if old_watch_id is not None:
        notifier.remove_watch_with_id(old_watch_id)
        logger.info(f"removing old watch [watch ID: {old_watch_id}]")

    update_handler(config, instrument, new_date)
    logger.info(f"watching for {instrument} data...")

    incoming_basedir = config.get(instrument, "incoming_basedir")
    incoming_dir = f"{incoming_basedir}/{new_date}"
    if not os.path.isdir(incoming_dir):
        os.mkdir(incoming_dir)
        logger.info(f"created new incoming directory {incoming_dir}")

    new_watch_id = notifier.add_watch(incoming_dir, WATCH_EVENT_FLAGS)
    logger.info(f"watching {incoming_dir} [watch ID: {new_watch_id}]")

    return new_watch_id


def update_handler(
    config: configparser.ConfigParser,
    instrument: str,
    date: str,
):
    """Update the logging handler to point to use the log file for the next day.
    [TODO]: should look into RotatingFileHandler for this.
    """
    year = date[0:4]

    if len(logger.handlers) > 0:
        logger.info(f"closing log")
        logger.removeHandler(logger.handlers[0])

    log_basename = config.get(instrument, "log_basename_format").format(date=date)
    logging_basedir = config.get(instrument, "logging_basedir")
    log_dir = f"{logging_basedir}/{year}"
    log_filename = f"{log_dir}/{log_basename}"
    if not os.path.isdir(log_dir):
        os.mkdir(log_dir)

    handler = logging.FileHandler(log_filename)
    handler.setLevel(logging.DEBUG)

    formatter = logging.Formatter(
        config.get(instrument, "log_format", raw=True),
        config.get(instrument, "log_date_format", raw=True),
    )
    handler.setFormatter(formatter)

    logger.addHandler(handler)


def setup_logger():
    """Setup the logger."""
    global logger   # change the global logger variable

    logging.addLevelName(logging.WARNING, "WARN")  # make same format as IDL logs

    logger = logging.getLogger("watchincoming")
    logger.setLevel(logging.DEBUG)


def main():
    """Entry point for watchincoming script. Parses command line arguments and
    starts watching for events.
    """
    desc = "MLSO incoming data watcher"
    parser = argparse.ArgumentParser(description=desc)
    parser.add_argument(
        "instrument",
        type=str,
        help="instrument to watch for, e.g., KCor, CoMP, UCoMP, etc.",
    )
    args = parser.parse_args()

    config_dirname = os.path.dirname(os.path.realpath(__file__))
    config_filename = f"{config_dirname}/watchincoming.cfg"
    config = configparser.ConfigParser()
    config.read(config_filename)

    instrument = args.instrument.lower()

    setup_logger()
    logger.info("starting service...")

    notifier = inotify.adapters.Inotify()

    watch_date = get_current_date()
    watch_id = change_date(config, instrument, notifier, None, watch_date)

    full_filesize = config.getint(instrument, "full_filesize")
    raw_basedir = config.get(instrument, "raw_basedir")

    received_first_file = False

    # main event loop
    try:
        for event in notifier.event_gen():
            if event is not None:
                # handle event
                _inotify_event, flags, dirname, basename = event
                logger.info(f"{basename} arrived")
                incoming_filename = f"{dirname}/{basename}"
                raw_dir = f"{raw_basedir}/{watch_date}"
                if not os.path.isdir(raw_dir):
                    os.mkdir(raw_dir)
                    logger.info(f"created new raw directory {raw_dir}")
                ok_file, is_machine_log, incoming_filesize = check_file(
                    incoming_filename,
                    full_filesize,
                    config.get(instrument, "machine_log_format").format(date=watch_date)
                )
                if ok_file:
                    # copy2 preserves metadata such as creation time, but not
                    # owner/group
                    shutil.copy2(incoming_filename, raw_dir)
                    os.chmod(f"{raw_dir}/{basename}", REQUIRED_PERMISSIONS)
                    logger.info(f"{basename} copied to {raw_dir}")
                else:
                    logger.warning(
                        f"{basename} incomplete, {incoming_filesize} != {full_filesize} bytes"
                    )
                    logger.warning("not copying")
                if not received_first_file:
                    notify(
                        config.get(instrument, "notification_email"),
                        f"Received {instrument} data for {watch_date}",
                        f"Received {basename} @ {datetime.datetime.now():%Y-%m-%dT%H:%M:%S}",
                    )
                    received_first_file = True
                if is_machine_log:
                    notify(
                        config.get(instrument, "notification_email"),
                        f"Received {instrument} machine log for {watch_date}",
                        f"Received {basename} @ {datetime.datetime.now():%Y-%m-%dT%H:%M:%S}",
                    )
            else:
                # check for date changes
                new_current_date = get_current_date()
                if watch_date != new_current_date:
                    watch_date = new_current_date
                    watch_id = change_date(
                        config, instrument, notifier, watch_id, watch_date,
                    )
                    received_first_file = False
    except KeyboardInterrupt as e:
        print()
        logger.info("quitting process")


if __name__ == "__main__":
    main()
